#Evaluation
#equal trend

data <- subset(data, subset = year > 2001 & year < 2009) 
plot_data<-data %>%
  mutate(treated=factor(treated,labels=c("Control","Treated")),
         year= factor(year))

plot_data=plot_data%>% group_by(treated,year)%>% 
  summarize(mean_consumption=mean(log_consumption),
            se_consumption= sd(log_consumption) /sqrt(n()),
            upper=mean_consumption +(1.96 *se_consumption),
            lower=mean_consumption +(-1.96 * se_consumption))

ggplot(plot_data, aes(x=year,y=mean_consumption,color=treated))+
  geom_smooth()+
  geom_line(aes(group=treated))+
  theme_minimal()

#Cohen D and independent T-test
treated_group_post <- data[data$treated == 1 & data$post == 1, "log_consumption"]
control_group_post <- data[data$treated == 0 & data$post == 1, "log_consumption"]

# 1. Independent t-test
t_test_result <- t.test(treated_group_post, control_group_post, var.equal = TRUE)
print("Independent t-test results:")
print(t_test_result)

# 2. Cohen's d
cohen_d_result <- cohen.d(treated_group_post, control_group_post)
print("Cohen's d results:")
print(cohen_d_result)


