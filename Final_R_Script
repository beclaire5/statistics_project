############################################################################
# DiD Regression Analysis
# Step 1: Remove rows where the dependent variable (consumption) is 0 (outlier) and log the consumption
data <- df %>% filter(consumption > 0)
data <- data %>% mutate(log_consumption = log(consumption))
# Create treatment and control groups
data <- data %>%
  mutate(
    treated = ifelse(age >= 16 & age <= 45 & child == 1, 1, 0) # Treatment group indicator
  )
# Add interaction terms for DiD regression
data <- data %>%
  mutate(
    post = ifelse(OFCOM == 1, 1, 0) # Post-treatment indicator
  )

# Step 2: Run the DiD regression
# Small model (fewer control variables)
small_model <- lm(
  log_consumption ~ treated:post + treated + post,
  data = data
)

# Big model (with additional control variables)
big_model <- lm(
  log_consumption ~ treated:post + treated + post + age + educ + male + married + income,
  data = data
)

# extract residuals of big model
residuals_big_model <- residuals(big_model)

# generate Q-Q plot
qqnorm(residuals_big_model, main = "Q-Q Plot of Residuals for Big Model")
qqline(residuals_big_model, col = "red", lwd = 2) 

# Step 3: Output by LaTex
stargazer(
  small_model, big_model,
  type = "latex",
  title = "Difference-in-Differences Regression Results",
  dep.var.labels = c("log_Consumption"),
  column.labels = c("Small Model", "Big Model"),
  model.numbers = FALSE,
  star.cutoffs = c(0.05, 0.01, 0.001), # Custom significance levels for stars
  notes.append = FALSE,                # Append a note on significance levels
  notes = "Significance levels: * p<0.05, ** p<0.01, *** p<0.001"
)
